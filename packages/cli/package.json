{
  "name": "@baron/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "baron": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@baron/core": "workspace:*",
    "@baron/knowledge-loop": "workspace:*",
    "@baron/providers": "workspace:*",
    "@baron/recipes": "workspace:*"
  },
  "devDependencies": {
    "@baron/conformance": "workspace:*",
    "@types/node": "^22.0.0"
  }
}
