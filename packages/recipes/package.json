{
  "name": "@baron/recipes",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "src", "recipes"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@baron/core": "workspace:*",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@baron/adapter-github": "workspace:*",
    "@baron/conformance": "workspace:*",
    "@types/node": "^22.0.0"
  }
}
