{
  "name": "@lonca/baron-mcp-server",
  "version": "0.15.0",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "baron-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lonca/baron-core": "workspace:*",
    "@lonca/baron-knowledge-loop": "workspace:*",
    "@lonca/baron-providers": "workspace:*",
    "@lonca/baron-recipes": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@lonca/baron-adapter-github": "workspace:*",
    "@lonca/baron-conformance": "workspace:*",
    "@types/node": "^22.0.0"
  },
  "description": "Baron MCP server: drive issues, scm, ci, deploy, and notify across providers from any MCP client.",
  "keywords": [
    "baron",
    "ai-agents",
    "mcp",
    "work-orchestration",
    "devops",
    "model-context-protocol",
    "claude",
    "server"
  ],
  "author": "Baron contributors",
  "homepage": "https://github.com/loncadev/baron#readme",
  "bugs": {
    "url": "https://github.com/loncadev/baron/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loncadev/baron.git",
    "directory": "packages/mcp-server"
  }
}
