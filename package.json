{
  "name": "baron-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Baron - platform-agnostic work-orchestration layer for AI coding agents",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
